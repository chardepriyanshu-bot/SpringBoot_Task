package com.pc.runner;

import java.util.Scanner;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.CommandLineRunner;
import org.springframework.stereotype.Component;

import com.pc.controller.CourseController;

@Component
public class CourseRunner implements CommandLineRunner {

	@Autowired
	private CourseController ctrl;
	@Override
	public void run(String... args) throws Exception {
		try {
			Scanner sc=new Scanner(System.in);
			
			do {
				
				System.out.println("""
						1. findByCategory(String category);
						2. findByInstructorName(String instructorName);
						3. findByPriceLessThan(Double price);
						4. findByPriceGreaterThan(Double price);
						5. findByDurationInHoursGreaterThan(Integer hours);
						6. findByRatingGreaterThanEqual(Double rating);
						7. findByLanguage(String language);
						8. findByCourseTitleContaining(String keyword);
						""");
				
			}while();
			
			
			
			sc.close();
		}catch(Exception e) {
			e.printStackTrace();
		}
	}

}
