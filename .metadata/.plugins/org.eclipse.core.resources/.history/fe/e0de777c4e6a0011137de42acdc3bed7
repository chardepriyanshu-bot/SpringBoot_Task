package com.pc;

import org.springframework.data.jpa.repository.JpaRepository;

import com.pc.entity.Doctor;

public interface IDoctorRepository extends JpaRepository<Doctor, Long> {
	findByDoctorNameLike(String pattern)
	findBySpecializationIn(List<String> specializations)
	findByDoctorNameStartingWith(String prefix)
	findByDoctorNameEndingWith(String suffix)
	findByCityIn(List<String> cities)
	findByHospitalNameLike(String pattern)
	findByEmailEndingWith(String domain)
	findBySpecializationStartingWith(String prefix)
}
